DRAGON_API_KEY=your_dragoncode_key
APP_USERNAME=admin
APP_PASSWORD_HASH=$2a$12$replace_with_bcrypt_hash
SESSION_SECRET=replace_with_at_least_32_random_characters
APP_BASE_URL=http://localhost:3000
# Production uses PostgreSQL when this is set.
DATABASE_URL=postgres://private_image_studio:change_me@127.0.0.1:5432/private_image_studio
# JSON remains useful for local fallback/tests when DATABASE_URL is not set.
DATABASE_PATH=./data/private-image-studio.json
